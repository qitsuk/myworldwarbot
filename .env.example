# Environment: set to "true" for development mode (fast ticks, debug logging)
DEBUG=false

# Discord webhook URL for notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Seconds per simulation month. Omit to use defaults (0.5 in dev, 3600 in prod)
# TIMESCALE=3600

# Flask secret key
SECRET_KEY=change-me
